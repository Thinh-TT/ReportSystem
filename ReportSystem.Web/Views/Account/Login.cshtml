@model ReportSystem.Web.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">
        <div class="card workspace-card">
            <div class="card-body">
                <h3 class="card-title mb-2">Sign In</h3>
                <p class="text-muted mb-3">Use your employee code to access role-based workspace.</p>

                <form asp-action="Login" asp-controller="Account" method="post" asp-route-returnUrl="@returnUrl">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                    <div class="mb-3">
                        <label asp-for="EmployeeCode" class="form-label"></label>
                        <input asp-for="EmployeeCode" class="form-control" autocomplete="username" />
                        <span asp-validation-for="EmployeeCode" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label"></label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Login</button>
                </form>

                <hr />
                <div class="section-title">Quick Test Users</div>
                <div class="d-grid gap-2">
                    <button type="button" class="btn btn-outline-secondary btn-sm quick-login" data-code="EMPLOYEE001">EMPLOYEE001 (EMPLOYEE)</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm quick-login" data-code="MANAGER001">MANAGER001 (MANAGER)</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm quick-login" data-code="ADMIN001">ADMIN001 (ADMIN)</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const input = document.getElementById("EmployeeCode");
            for (const button of document.querySelectorAll(".quick-login")) {
                button.addEventListener("click", () => {
                    input.value = button.dataset.code || "";
                    input.focus();
                });
            }
        });
    </script>
}
