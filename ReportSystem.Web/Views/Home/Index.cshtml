@using System.Security.Claims
@{
    ViewData["Title"] = "Dashboard";
    var employeeCode = User.FindFirst("employee_code")?.Value ?? "-";
}

<div class="page-hero mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <h1 class="h3 mb-1">Dashboard</h1>
            <div class="mb-0">Welcome back, <strong>@User.Identity?.Name</strong> (@employeeCode)</div>
        </div>
        <div class="d-flex flex-wrap gap-2">
            @if (User.IsInRole("EMPLOYEE") || User.IsInRole("ADMIN"))
            {
                <a class="btn btn-light btn-sm" asp-controller="Employee" asp-action="Index">Go Employee Workspace</a>
            }
            @if (User.IsInRole("MANAGER") || User.IsInRole("ADMIN"))
            {
                <a class="btn btn-light btn-sm" asp-controller="Manager" asp-action="Index">Go Manager Workspace</a>
            }
            @if (User.IsInRole("ADMIN"))
            {
                <a class="btn btn-light btn-sm" asp-controller="Admin" asp-action="Index">Go Admin Workspace</a>
            }
        </div>
    </div>
</div>

<div class="row g-3">
    @if (User.IsInRole("EMPLOYEE") || User.IsInRole("ADMIN"))
    {
        <div class="col-lg-4 col-md-6">
            <div class="card workspace-card h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Employee Flow</h5>
                    <p class="card-text text-muted">
                        Create draft, fill field values, upload attachment, and submit report.
                    </p>
                    <a class="btn btn-primary mt-auto" asp-controller="Employee" asp-action="Index">Open Employee</a>
                </div>
            </div>
        </div>
    }

    @if (User.IsInRole("MANAGER") || User.IsInRole("ADMIN"))
    {
        <div class="col-lg-4 col-md-6">
            <div class="card workspace-card h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Manager Flow</h5>
                    <p class="card-text text-muted">
                        Filter submissions, evaluate, approve/reject, reopen, and open detail/export.
                    </p>
                    <a class="btn btn-primary mt-auto" asp-controller="Manager" asp-action="Index">Open Manager</a>
                </div>
            </div>
        </div>
    }

    @if (User.IsInRole("ADMIN"))
    {
        <div class="col-lg-4 col-md-6">
            <div class="card workspace-card h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Admin Flow</h5>
                    <p class="card-text text-muted">
                        Manage users/roles and template lifecycle safely for future expansion.
                    </p>
                    <a class="btn btn-primary mt-auto" asp-controller="Admin" asp-action="Index">Open Admin</a>
                </div>
            </div>
        </div>
    }
</div>
